# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=REDDYMATKA

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# OTP (for development, OTP is logged to console)
OTP_EXPIRY_MINUTES=5

# Twilio (required in production for real OTP delivery)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_OTP_TEMPLATE=Your REDDYMATKA OTP is {{otp}}. Valid for {{expiryMinutes}} minutes.

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
